# ── Application ───────────────────────────────────────────────
APP_NAME="CAD-CAE Analyzer"
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ── Database ──────────────────────────────────────────────────
# SQLite (local dev, no Docker needed):
DATABASE_URL=sqlite+aiosqlite:///./backend/cae_local.db
# PostgreSQL (Docker / production):
# DATABASE_URL=postgresql+asyncpg://cae:cae@localhost:5432/caedb

# ── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Storage ───────────────────────────────────────────────────
# Local file storage (dev):
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./backend/storage
# S3-compatible (production):
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=cae-files
# S3_ENDPOINT_URL=                    # leave blank for AWS, set for MinIO

# ── Solvers ───────────────────────────────────────────────────
# Path to solver binaries (in Docker these are on PATH)
CCX_BINARY=ccx                        # CalculiX
GMSH_BINARY=gmsh                      # gmsh (usually handled by Python API)
OPENFOAM_SCRIPT=/opt/openfoam10/etc/bashrc   # source before running solvers

# Mock mode: return synthetic results without running real solvers
MOCK_SOLVER_MODE=true                  # set false when running inside Docker with real solvers

# ── CAD Parsing ───────────────────────────────────────────────
# true = use trimesh only (works on Windows natively)
# false = use pythonocc-core (requires OpenCASCADE, Linux/Docker recommended)
MOCK_CAD_MODE=false

# ── Chatbot (Claude API) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5
RAG_COLLECTION_NAME=cae_knowledge

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8001","http://127.0.0.1:8001","null"]

# ── Misc ──────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=500
ALLOWED_EXTENSIONS=.step,.stp,.iges,.igs,.stl,.obj,.ply
JOB_TIMEOUT_SECONDS=3600
